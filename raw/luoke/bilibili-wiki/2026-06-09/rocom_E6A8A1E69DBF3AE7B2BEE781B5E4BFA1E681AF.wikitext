{{#css:
.isla_rocom_sprite.visible-sm,.isla_rocom_sprite.visible-xs {
    padding: 10px;
}
.visible-sm .rocom_sprite_layout_1,
.visible-xs .rocom_sprite_layout_1,
.visible-sm .rocom_sprite_layout_2,
.visible-xs .rocom_sprite_layout_2{
    flex-direction: column;
}
.visible-sm .rocom_sprite_grament,
.visible-xs .rocom_sprite_grament {
    border-top: 1px solid #292b2e;
    border-left: 1px solid #292b2e;
    border-right: 1px solid #292b2e;
}
.visible-sm .rocom_sprite_grament,
.visible-xs .rocom_sprite_grament,
.visible-sm .rocom_sprite_info,
.visible-xs .rocom_sprite_info {
    width: 100%;
    padding: 20px;
}
.visible-sm .rocom_sprite_grament_img li,
.visible-xs .rocom_sprite_grament_img li {
    height: 100%;
    padding: 20px;
}
.visible-sm .rocom_sprite_grament_list,
.visible-xs .rocom_sprite_grament_list {
    display: grid;
    grid-template-columns: repeat(auto-fill,20%);
    gap: 5px;
    width: 100%;
    justify-content: center;
    text-align: center;
}
.visible-sm .rocom_sprite_grament_list li,
.visible-xs .rocom_sprite_grament_list li,
.visible-sm .rocom_sprite_grament_list li img,
.visible-xs .rocom_sprite_grament_list li img {
    width:auto;
    height:auto;
    margin:0;
}
.visible-sm .rocom_sprite_characteristic,
.visible-sm .rocom_sprite_characteristic {
    width: 100%;
    padding: 20px 10px 0px 10px;
}
.visible-sm .rocom_sprite_temp_attribute_box,
.visible-xs .rocom_sprite_temp_attribute_box {
    margin: 10px 0 10px;
}
.visible-sm .rocom_sprite_temp_evolve_rightBox,
.visible-xs .rocom_sprite_temp_evolve_rightBox {
    border-left: 1px solid #292b2e;
    border-right: 1px solid #292b2e;
    border-bottom: 1px solid #292b2e;
}
.visible-sm .rocom_sprite_temp_attributesText_box,
.visible-xs .rocom_sprite_temp_attributesText_box {
display: grid;
    align-items: center;
    justify-content: flex-start;
    grid-template-columns: repeat(auto-fill,30%);
}
.visible-sm .rocom_sprite_temp_attributes_box,
.visible-xs .rocom_sprite_temp_attributes_box,
.visible-sm .rocom_sprite_temp_attributesText_box p,
.visible-xs .rocom_sprite_temp_attributesText_box p,
.visible-sm .rocom_sprite_temp_evolve_rightBox,
.visible-xs .rocom_sprite_temp_evolve_rightBox,
.visible-sm .rocom_sprite_layout_3 > div:nth-child(2),
.visible-xs .rocom_sprite_layout_3 > div:nth-child(2),
.visible-sm ul.tabbernav li a,.visible-sm ul.tabbernav li.tabberactive a,
.visible-xs ul.tabbernav li a,.visible-xs ul.tabbernav li.tabberactive a {
    width: 100%;
}
.visible-sm .rocom_sprite_layout_3,
.visible-xs .rocom_sprite_layout_3,
.visible-sm .rocom_sprite_restrain,
.visible-xs .rocom_sprite_restrain {
    padding:10px;
}
.visible-sm .rocom_sprite_skill_skillBox,
.visible-xs .rocom_sprite_skill_skillBox {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(1,100%);
}
.visible-sm .rocom_sprite_skill_box,
.visible-xs .rocom_sprite_skill_box {
    width: 100%;
    margin: 0;
}
.visible-sm .rocom_sprite_skill_tabBox ul.tabbernav,
.visible-xs .rocom_sprite_skill_tabBox ul.tabbernav {
    display: grid;
    grid-template-columns: repeat(10,10%);
    width: 100%;
    margin: 0;
}
.visible-sm ul.tabbernav li,
.visible-xs ul.tabbernav li {
    margin: 0;
}
.visible-sm .rocom_sprite_skill_tabBox ul.tabbernav li:nth-child(1),
.visible-xs .rocom_sprite_skill_tabBox ul.tabbernav li:nth-child(1),
.visible-sm .rocom_sprite_skill_tabBox ul.tabbernav li:nth-child(3),
.visible-xs .rocom_sprite_skill_tabBox ul.tabbernav li:nth-child(3) {
    grid-column: span 3;
}
.visible-sm .rocom_sprite_skill_tabBox ul.tabbernav li:nth-child(5),
.visible-xs .rocom_sprite_skill_tabBox ul.tabbernav li:nth-child(5) {
    grid-column: span 4;
}
.visible-sm .rocom_sprite_skill_tabBox ul.tabbernav wbr,
.visible-xs .rocom_sprite_skill_tabBox ul.tabbernav wbr {
    display:none;
}

