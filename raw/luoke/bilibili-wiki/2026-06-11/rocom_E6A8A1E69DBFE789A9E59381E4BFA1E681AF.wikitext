{{#css:
 .isla_rocom_item_page {
  display: flex;
  padding: 30px;
  background-color: #292d2e;
  border-radius: 50px;
 }
 .rocom_item_page_img {
  width: calc(30% - 30px);
  margin-right: 30px;
  display: flex;
  justify-content: center;
  align-items: flex-start;
 }
 .rocom_item_page_img img {
  max-width: 100%;
  height: auto;
 }
 .rocom_item_page_info {
  width: 70%;
 }
 .rocom_item_page_info_title {
  display: flex;
  padding-bottom: 12px;
  margin-bottom: 8px;
  border-bottom: 2px solid #515151;
  justify-content: space-between;
  align-items: flex-end;
 }
 .rocom_item_page_info_title_left p {
  font-size: 26px;
  margin: 0px;
  letter-spacing: 3px;
  color: rgba(239, 237, 237, 1.0);
 }
 .rocom_item_page_info_title_right p {
  font-size: 16px;
  margin: 0px;
  color: rgba(255, 255, 255, 0.6);
 }
 .rocom_item_page_info_subheading {
  margin-top: 12px;
  margin-bottom: 6px;
  padding-bottom: 8px;
  border-bottom: 2px solid #515151;
 }
 .rocom_item_page_info_subheading p {
  margin: 0px;
 }
 .rocom_item_page_info_content p {
  font-size: 15px;
  color: rgba(0, 0, 0, 0.6);
 }
 .rocom_item_page_info_content b {
  margin-bottom: 8px;
  font-weight: normal;
  display: inline-block;
 }
 .rocom_item_page_info_list_form {
  display: flex;
  align-items: center;
  margin-bottom: 6px;
 }
 .rocom_item_page_info_list_form img {
  margin-right: 8px;
 }

 @media screen and (max-width: 768px) {
  .isla_rocom_item_page {
   flex-direction: column;
   padding: 20px;
   border-radius: 20px;
   align-items: center;
  }
  .rocom_item_page_img {
   width: 120px;
   margin-right: 0px;
   margin-bottom: 20px;
  }
  .rocom_item_page_info {
   width: 100%;
  }
  .rocom_item_page_info_title {
   flex-direction: column;
   align-items: flex-start;
   gap: 5px;
  }
  .rocom_item_page_info_title_left p {
   font-size: 22px;
  }
  .rocom_item_page_info_title_right p {
   font-size: 14px;
  }
 }
}}