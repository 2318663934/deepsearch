# 环境与密钥
.env
*.env
!/.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
.venv/
venv/
env/

# Claude Code 配置目录（项目级，不入仓）
.claude/

# 临时文件
*.log
state/discarded.log
state/*.tmp

# raw/ 下的二进制大文件（可选）
raw/**/*.png
raw/**/*.jpg
raw/**/*.jpeg
raw/**/*.gif
raw/**/*.pdf
raw/**/*.zip

# 爬取缓存
raw/**/cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 用户的项目实施记录文件（与代码无关）
*.docx
~$*.docx

# 爬取的 HTML/TXT 是中间产物，体积大，按需保留
# 取消下一行的注释以入仓；当前不入仓（爬虫可重建）
raw/wangzhe/sogou-baike/
raw/wangzhe/moegirl-baike/
raw/wangzhe/moegirl-baike_sub/

# scripts/_tmp 是用户工作目录里的临时文件，不入仓
scripts/_tmp/
