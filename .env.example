# 本地 llama.cpp 配置（OpenAI 兼容协议）
# 部署方式：llama.cpp HTTP server，默认端口 8080
# 模型名必须与 /v1/chat/completions 响应中的 model 字段一致
LLAMACPP_BASE_URL=http://192.168.100.211:8080/v1
LLAMACPP_MODEL=Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive-Q4_K_P.gguf
LLAMACPP_API_KEY=llamacpp

# 云端 MiniMax-M3 配置（Anthropic 兼容协议）
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_MODEL=MiniMax-M3
# 填入你的 API Key
ANTHROPIC_API_KEY=sk-cp-YOUR_KEY_HERE
